{
  "name": "CapTube (Dual Captions for YouTube)",
  "manifest_version": 3,
  "author": "Dan Chen",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://www.youtube.com/*",
    "https://tmt.tencentcloudapi.com/*",
    "https://api.deepl.com/*"
  ],

  "action": {
    "default_icon": "icon-gray.png",
    "default_popup": "popup.html"
  },

  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "128": "icon128.png",
    "512": "icon.png"
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.min.js"],
      "run_at": "document_end"
    }
  ],

  "externally_connectable": {
    "matches": ["https://www.youtube.com/*"]
  },

  "web_accessible_resources": [
    {
      "resources": ["captube.min.js", "icon32.png"],
      "matches": ["https://www.youtube.com/*"]
    }
  ],

  "options_ui": {
    "page": "options.html"
  }
}
